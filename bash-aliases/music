# kill processes then open navidrome, because navidrome is... parasitic
# also should be in ~/.config to use LastFM API keys there
alias nd="cd /home/jacob/.config/navidrome/ && sudo killall navidrome || true && navidrome"


# print cumulative runtime for all wavs, flacs and mp3's in the working directory
alias track-runtime="find . -maxdepth 1 \( -iname \"*.wav\" -o -iname \"*.flac\" \) -exec ffprobe -v quiet -of csv=p=0 -show_entries format=duration {} \; | paste -sd+ - | bc | awk '{printf(\"%d:%02d:%02d\n\", (\$1/3600), (\$1/60)%60, \$1%60)}'"

