#
# run xdg-open & free terminal session without killing running process
xo() {
    xdg-open "$@" &>/dev/null 2>1 & disown
}

# open docker desktop on this system
alias docker_desktop="systemctl --user start docker-desktop"

# ls aliases
alias llh="ls | head"
lth() {
  ls -t "${1:-.}" | head -n 1
}
alias ltx="ls -t | head -n 1 | xargs xdg-open"
alias ltr="ls -t | head -n 1 | xargs rm"

# count number of visible entries in topmost parent directory of WD
alias dir_top="ls -1F | grep -v / | wc -l"

# arch-wiki-docs main
alias arch-wiki-docs="cd /usr/share/doc/arch-wiki/html/en"

alias desktops="cd /home/jacob/.local/share/applications"

# pictures stored in Steam (update if needed)
alias steam_pics="cd ~/.local/share/Steam/userdata/102112720/760/remote/4570/screenshots/"

# rm interactive using fzf
alias rmi='find . -print0 | sort -z | fzf --read0 -m --print0 | xargs -0 sudo rm -r'

# cd interactive using fzf
cdi() {
  local dir
  dir=$(find . -type d -print0 | sort -z | fzf --read0)

  # Only run cd if you actually picked something (prevents crashing/resetting if you hit ESC)
  if [ -n "$dir" ]; then
    cd "$dir"
  fi
}

# mv interactive; specify an argument for folder to move to
alias mvi='mvi() { find . -maxdepth 1 -type f -print0 | sort -z | fzf --read0 -m --print0 | xargs -0 -o -I {} mv {} "$1"; }; mvi'

# xdg-open interactive
alias xoi='find . -print0 | sort -z | fzf --read0 -m --print0 | xargs -0 xdg-open'

