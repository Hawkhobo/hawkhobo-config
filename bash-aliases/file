# run xdg-open & free terminal session without killing running process
xo() {
    xdg-open "$@" &>/dev/null 2>1 & disown
}

# open docker desktop on this system
alias docker_desktop="systemctl --user start docker-desktop"

# ls aliases
alias lth="ls -t | head"
# open the most recent file added to the current working directory
alias ltx="ls -t | head -n 1 | xargs xdg-open"

# count number of visible entries in topmost parent directory of WD
alias dir_top="ls -1F | grep -v / | wc -l"

# download directory of soulseek nicotine+ app
alias slsk-dir="cd /home/jacob/.local/share/nicotine/downloads"

# shortcut for markdown software of choice
md() {
    frogmouth "$@"
}

# arch-wiki-docs main
alias arch-wiki-docs="cd /usr/share/doc/arch-wiki/html/en"

# kill processes then open navidrome, because navidrome is... parasitic
# also should be in ~/.config to use LastFM API keys there
alias nd="cd /home/jacob/.config/navidrome/ && sudo killall navidrome || true && navidrome"

alias desktops="cd /home/jacob/.local/share/applications"
