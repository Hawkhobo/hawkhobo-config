# ignore discord/ directory (only config is settings.json, system-level)
discord/

# only save Qbittorrent settings
qBittorrent/*
!qBittorrent/
!qBittorrent/*.conf

# ignore Navidrome dependencies
navidrome/plugins
*navidrome.db*
*cache

bash-aliases/discord

# beets files
*musiclibrary.db
*state.pickle

# don't include bank container files (spotify and other audio services)
*.bnk

# SQL files
*sqlite*

*.xml

# ignore non-configurable applications (or those configured in-session)
Code/
dconf/
evolution/
font-manager/
GIMP/
go/
hyperbeam/
inkscape/
jxbrowser/
k3brc
libreoffice/
LyX/
Notion/
obs-studio/
okularrc
okularpartrc
qBittorrent/
# dolphin text editor
session/
Slack/
Signal/
strawberry/
teams-for-linux/
texlive/
zoom/


# ignore build files and dad's dotfiles
*dotfiles.2026*
*.tgz

*config.old

# specific config files that are auto-generated
QtProject.conf
audacity/audacity.cfg
kid3rc
nicotine/config
zoomus.conf
zoom.conf

#miscellanous
emaildefaults
menus/

